# MCP Transport: "stdio" (default) or "streamable-http"
# MCP_TRANSPORT=stdio

# Host and port for streamable-http transport
# MCP_HOST=0.0.0.0
# MCP_PORT=3000

# Tekna API timeout in seconds (default 30)
# TEKNA_TIMEOUT=30

# Cache TTL in seconds (default 900 = 15 minutes)
# TEKNA_CACHE_TTL=900

# Log level (default INFO)
# LOG_LEVEL=INFO
